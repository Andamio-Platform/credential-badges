# Andamio API service keys for the on-demand badge render service (#33).
#
# Copy this file to `.env.local` (gitignored) and fill in real keys.
# NEVER commit real keys. `.env.local`, `.env`, and `*.env.*` are all gitignored;
# only this `.env.example` (placeholders only) is tracked.
#
# Keys are NETWORK-SCOPED (U1 gate finding, docs/spikes/2026-06-25-gateway-key-verification.md):
# a mainnet-issued key returns 401 on the preprod gateway. The render service
# selects the key by the course's network and calls the matching gateway.
#
# Endpoints used (read-only):
#   GET /api/v2/course/user/course/get/{course_id}   -> data.content.title
#   GET /api/v2/course/user/modules/{course_id}      -> data[].content.title, slt_hash, on_chain_slts

# Preprod — reads https://preprod.api.andamio.io (the deployed Developers badges are preprod)
ANDAMIO_PREPROD_API_KEY=ant_replace_me

# Mainnet — reads https://api.andamio.io (e.g. Join Cardano XP, Gimbalabs)
ANDAMIO_MAINNET_API_KEY=ant_replace_me
